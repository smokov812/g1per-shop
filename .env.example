BOT_TOKEN=your_telegram_bot_token
ADMIN_ID=123456789
SUPPORT_USERNAME=@support_username

# Для MVP подойдет SQLite.
# Для production лучше сразу перейти на Postgres:
# DATABASE_URL=postgresql+asyncpg://shop_user:shop_pass@127.0.0.1:5432/shop_db
DATABASE_URL=sqlite+aiosqlite:///shop.db
CURRENCY=USDT

PAYMENT_PROVIDER=manual_crypto
ENABLED_PAYMENT_PROVIDERS=manual_crypto
CRYPTO_ASSET=USDT
CRYPTO_NETWORK=TRC20
CRYPTO_WALLET=TRXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
PAYMENT_MESSAGE=Оплата принимается только криптовалютой. После оформления админ пришлет реквизиты и сумму к оплате.
ORDER_MANAGER_USERNAME=@manager_username

CRYPTOMUS_MERCHANT_ID=
CRYPTOMUS_API_KEY=
CRYPTOMUS_NETWORK=TRON
CRYPTOMUS_RETURN_URL=https://example.com/return
CRYPTOMUS_SUCCESS_URL=https://example.com/success
CRYPTOMUS_WEBHOOK_ENABLED=false
CRYPTOMUS_WEBHOOK_PATH=/webhooks/cryptomus
CRYPTOMUS_WEBHOOK_URL=https://example.com/webhooks/cryptomus
CRYPTOMUS_ALLOWED_IPS=91.227.144.54

LZT_MARKET_API_KEY=
LZT_MARKET_MERCHANT_ID=
LZT_MARKET_MERCHANT_SECRET=
LZT_MARKET_CURRENCY=RUB
LZT_MARKET_SUCCESS_URL=https://example.com/lzt-success
LZT_MARKET_WEBHOOK_ENABLED=false
LZT_MARKET_WEBHOOK_PATH=/webhooks/lzt-market
LZT_MARKET_WEBHOOK_URL=https://example.com/webhooks/lzt-market
LZT_MARKET_STRICT_WEBHOOK_SIGNATURE=false
LZT_MARKET_LIFETIME_MINUTES=60

WEB_SERVER_ENABLED=true
WEB_SERVER_HOST=0.0.0.0
WEB_SERVER_PORT=8080
TRUST_PROXY_HEADERS=false

PAYMENT_SYNC_ENABLED=true
PAYMENT_SYNC_INTERVAL_SECONDS=60
PAYMENT_SYNC_STALE_SECONDS=180
PAYMENT_SYNC_BATCH_SIZE=20

MESSAGE_RATE_LIMIT_SECONDS=0.8
CALLBACK_RATE_LIMIT_SECONDS=0.4

